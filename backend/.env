# ─────────────────────────────────────────────────
# QMedia Backend – Environment Variables
# Fill these values before running npm run dev
# ─────────────────────────────────────────────────

PORT=5000

# Local MongoDB:  mongodb://localhost:27017/qmedia
# MongoDB Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/qmedia
MONGODB_URI=mongodb://localhost:27017/qmedia

# Change this to a long random string in production
JWT_SECRET=qmedia_super_secret_key_change_this_2024

# Token expiry
JWT_EXPIRES_IN=7d

# React frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
